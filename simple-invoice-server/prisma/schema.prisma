// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InvoiceStatus {
  Draft
  Pending
  Paid
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullname     String
  createdAt    DateTime  @default(now())
  invoices     Invoice[]
}

model Invoice {
  invoiceId        String        @id @default(uuid())
  invoiceNumber    String        @unique
  invoiceReference String?
  invoiceDate      DateTime      @db.Date
  dueDate          DateTime      @db.Date
  currency         String
  currencySymbol   String
  description      String?
  status           InvoiceStatus @default(Draft)
  invoiceSubTotal  Decimal       @db.Decimal(15, 2)
  totalTax         Decimal       @db.Decimal(15, 2)
  totalDiscount    Decimal       @db.Decimal(15, 2)
  totalAmount      Decimal       @db.Decimal(15, 2)
  totalPaid        Decimal       @default(0) @db.Decimal(15, 2)
  balanceAmount    Decimal       @db.Decimal(15, 2)
  // Customer fields (embedded)
  customerFullname String
  customerEmail    String
  customerMobile   String?
  customerAddress  String?
  createdAt        DateTime      @default(now())
  createdBy        String
  user             User          @relation(fields: [createdBy], references: [id])
  items            InvoiceItem[]

  @@index([invoiceNumber])
  @@index([status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@index([customerFullname])
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  name      String
  quantity  Int
  rate      Decimal @db.Decimal(15, 2)
  invoice   Invoice @relation(fields: [invoiceId], references: [invoiceId], onDelete: Cascade)
}
